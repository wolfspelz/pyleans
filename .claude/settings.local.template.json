{
  "permissions": {
    "allow": [
      "Bash(.venv/Scripts/pip *)",
      "Bash(.venv/Scripts/python *)",
      "Bash(.venv/Scripts/pytest *)",
      "Bash(.venv/Scripts/mypy *)",
      "Bash(.venv/Scripts/ruff *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(mv *)",
      "Bash(source .venv/*)",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebFetch(domain:pypi.org)",
      "WebFetch(domain:github.com)",
      "Bash(python -m venv .venv)",
      "Bash(.venv/Scripts/python.exe -m pip install *)",
      "Bash(.venv/Scripts/python.exe -m pytest)"
    ]
  }
}
